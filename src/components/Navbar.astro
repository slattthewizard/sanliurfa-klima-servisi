---
interface Props {
  activePage?: string;
}
const { activePage = '' } = Astro.props;

const links = [
  { href: '/', label: 'Ana Sayfa', id: 'home' },
  { href: '/services', label: 'Hizmetler', id: 'services' },
  { href: '/about', label: 'Hakkımızda', id: 'about' },
  { href: '/blog', label: 'Blog', id: 'blog' },
];
---

<nav class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a href="/" class="flex-shrink-0">
        <img src="/brand_assets/logo.webp" alt="Şanlıurfa Klima Servisi" class="h-12">
      </a>
      <div class="hidden lg:flex items-center gap-8">
        {links.map(link => (
          <a
            href={link.href}
            class={`nav-link font-semibold text-sm uppercase tracking-wide focus-visible:outline-2 focus-visible:outline-brand-orange focus-visible:outline-offset-2 ${activePage === link.id ? 'text-brand-orange' : 'text-brand-navy'}`}
          >
            {link.label}
          </a>
        ))}
      </div>
      <div class="hidden lg:flex items-center">
        <a href="tel:+905533975244" class="btn-orange inline-flex items-center gap-2 bg-brand-orange text-white font-bold text-sm px-6 py-3 rounded-full focus-visible:outline-2 focus-visible:outline-brand-orange focus-visible:outline-offset-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
          0553 397 52 44
        </a>
      </div>
      <button id="menuToggle" class="lg:hidden p-2 rounded-md text-brand-navy focus-visible:outline-2 focus-visible:outline-brand-orange" aria-label="Menüyü aç/kapat">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  <div id="mobileMenu" class="mobile-menu lg:hidden bg-white border-t border-gray-100">
    <div class="px-4 py-4 flex flex-col gap-3">
      {links.map(link => (
        <a
          href={link.href}
          class={`nav-link font-semibold text-sm uppercase tracking-wide py-2 ${activePage === link.id ? 'text-brand-orange' : 'text-brand-navy'}`}
        >
          {link.label}
        </a>
      ))}
      <a href="tel:+905533975244" class="btn-orange inline-flex items-center justify-center gap-2 bg-brand-orange text-white font-bold text-sm px-6 py-3 rounded-full mt-2">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
        0553 397 52 44
      </a>
    </div>
  </div>
</nav>

<script>
  document.getElementById('menuToggle')?.addEventListener('click', () => {
    document.getElementById('mobileMenu')?.classList.toggle('open');
  });
</script>
