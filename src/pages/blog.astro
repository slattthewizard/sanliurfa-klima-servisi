---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Blog | Şanlıurfa Klima Servisi"
  description="Şanlıurfa Klima Servisi blog - Klima bakımı, enerji tasarrufu ve iklimlendirme ipuçları."
  activePage="blog"
>
  <!-- ============ BREADCRUMB ============ -->
  <div class="bg-brand-cream">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <nav class="flex items-center gap-2 text-gray-400 text-sm">
        <a href="/" class="footer-link hover:text-brand-orange">Ana Sayfa</a>
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
        <span class="text-gray-300">Blog</span>
      </nav>
    </div>
  </div>

  <!-- ============ BLOG PLACEHOLDER ============ -->
  <section class="py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-brand-orange font-bold text-sm uppercase tracking-widest mb-4">Blog</span>
      <h1 class="font-heading font-extrabold text-3xl sm:text-4xl text-brand-navy mb-6" style="letter-spacing: -0.03em;">
        Yakında Burada
      </h1>
      <p class="text-text-body text-lg leading-relaxed mb-10" style="line-height: 1.7;">
        Klima bakımı, enerji tasarrufu ipuçları ve iklimlendirme dünyasından güncel yazılarımız çok yakında burada olacak.
      </p>
      <a href="/" class="btn-orange inline-flex items-center gap-2 bg-brand-orange text-white font-bold text-sm px-8 py-4 rounded-full focus-visible:outline-2 focus-visible:outline-brand-orange focus-visible:outline-offset-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Ana Sayfaya Dön
      </a>
    </div>
  </section>
</Layout>
