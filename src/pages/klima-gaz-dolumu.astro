  <!-- FAQ Toggle Script -->
  <script>
    function toggleFaq(button: HTMLButtonElement) {
      const answer = button.nextElementSibling as HTMLElement;
      const chevron = button.querySelector('.faq-chevron') as SVGElement;
      const isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all other FAQs
      document.querySelectorAll('.faq-answer').forEach((el) => {
        (el as HTMLElement).style.maxHeight = '0px';
        (el as HTMLElement).style.opacity = '0';
      });
      document.querySelectorAll('.faq-chevron').forEach((el) => {
        (el as SVGElement).style.transform = 'rotate(0deg)';
      });

      if (!isOpen) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        answer.style.opacity = '1';
        chevron.style.transform = 'rotate(180deg)';
      }
    }

    // Initialize FAQ answers as hidden
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.faq-answer').forEach((el) => {
        (el as HTMLElement).style.maxHeight = '0px';
        (el as HTMLElement).style.opacity = '0';
        (el as HTMLElement).style.overflow = 'hidden';
        (el as HTMLElement).style.transition = 'max-height 0.3s ease, opacity 0.3s ease';
      });
      document.querySelectorAll('.faq-chevron').forEach((el) => {
        (el as SVGElement).style.transition = 'transform 0.3s ease';
      });
    });
  </script>
</Layout>
