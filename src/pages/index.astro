---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Şanlıurfa Klima Servisi | Montaj, Bakım, Tamir & Gaz Dolumu"
  description="Şanlıurfa klima servisi - Profesyonel klima montaj, bakım, tamir ve gaz dolumu hizmetleri. 7/24 acil servis. Haliliye, Karaköprü, Eyyübiye ve tüm Şanlıurfa'ya hizmet veriyoruz. Hemen arayın!"
  activePage="home"
>
  <Fragment slot="head">
    <meta name="keywords" content="şanlıurfa klima servisi, urfa klima montaj, şanlıurfa klima bakım, klima tamir şanlıurfa, klima gaz dolumu şanlıurfa">
    <script type="application/ld+json" set:html={`{
    "@context": "https://schema.org",
    "@type": "HVACBusiness",
    "name": "Şanlıurfa Klima Servisi",
    "url": "https://sanliurfaklimaservisi.com",
    "telephone": "+90-553-397-5244",
    "email": "info@sanliurfaklimaservisi.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Şanlıurfa",
      "addressRegion": "Şanlıurfa",
      "addressCountry": "TR"
    },
    "areaServed": ["Haliliye", "Karaköprü", "Eyyübiye", "Şanlıurfa"],
    "openingHours": "Mo-Sa 08:00-20:00",
    "priceRange": "₺₺",
    "description": "Şanlıurfa'nın güvenilir klima servisi. Profesyonel montaj, bakım, tamir ve gaz dolumu hizmetleri.",
    "serviceArea": {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 37.1591, "longitude": 38.7969 },
      "geoRadius": "50000"
    }
  }`}></script>
  </Fragment>

  <!-- ============ SECTION 3: HERO ============ -->
  <section class="relative overflow-hidden bg-white" style="min-height: 620px;">
    <!-- Background image (right side) -->
    <div class="absolute inset-0">
      <img src="/brand_assets/hero-technician-indoor.webp" alt="Klima Teknisyeni" class="w-full h-full object-cover object-right">
      <div class="absolute inset-0 bg-gradient-to-r from-white/40 to-transparent"></div>
    </div>
    <!-- White curved overlay (left side) - S-curve shape -->
    <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1440 620" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,0 L860,0 Q920,120 800,280 Q680,440 860,620 L0,620 Z" fill="white"/>
    </svg>
    <!-- Hero Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: 620px;">
      <div class="max-w-lg py-16 lg:py-24">
        <span class="inline-block text-brand-orange font-bold text-sm uppercase tracking-widest mb-4">Klima Montaj & Servis</span>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-[3.4rem] font-extrabold text-brand-navy leading-[1.1] tracking-[-0.03em] mb-6">
          ŞANLIURFA KLİMA<br>SERVİSİ
        </h1>
        <p class="text-text-body text-base leading-relaxed mb-8 max-w-md" style="line-height: 1.7;">
          Profesyonel klima montaj, bakım, tamir ve gaz dolumu hizmetleri. Haliliye, Karaköprü, Eyyübiye ve tüm Şanlıurfa'ya 7/24 hizmet veriyoruz.
        </p>
        <a href="#contact" class="btn-orange inline-flex items-center gap-2 bg-brand-orange text-white font-bold text-base px-8 py-4 rounded-full focus-visible:outline-2 focus-visible:outline-brand-orange focus-visible:outline-offset-2">
          ÜCRETSİZ TEKLİF ALIN
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
    <!-- Bottom curve divider -->
    <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,100 C360,20 1080,20 1440,100 L1440,100 L0,100 Z" fill="#f5f0eb"/>
    </svg>
  </section>

  <!-- ============ SECTION 4: SERVICES CARDS ============ -->
  <section id="services" class="bg-brand-cream pt-16 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Section Heading -->
      <div class="text-center mb-14">
        <span class="text-brand-orange font-bold text-sm uppercase tracking-widest">Hizmetlerimiz</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-brand-navy mt-3 tracking-[-0.03em]">HER ŞEYİ BİZ HALLEDERIZ</h2>
        <div class="w-16 h-1 bg-brand-orange mx-auto mt-4 rounded-full"></div>
      </div>
      <!-- Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-7">
        <!-- Card 1: AC Repair -->
        <div class="card-lift bg-white rounded-2xl shadow-card p-7 text-center">
          <div class="w-16 h-16 bg-brand-orange/10 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Klima Montaj</h3>
          <p class="text-text-body text-sm leading-relaxed mb-4">Uzman ekibimizle profesyonel klima montaj hizmeti. Tüm marka ve modellerde kurulum yapıyoruz.</p>
          <a href="#" class="text-brand-orange font-semibold text-sm nav-link focus-visible:outline-2 focus-visible:outline-brand-orange">Detaylı Bilgi &rarr;</a>
        </div>
        <!-- Card 2: Heating -->
        <div class="card-lift bg-white rounded-2xl shadow-card p-7 text-center">
          <div class="w-16 h-16 bg-brand-orange/10 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Klima Bakım</h3>
          <p class="text-text-body text-sm leading-relaxed mb-4">Düzenli klima bakımı ile cihazınızın ömrünü uzatın. Filtre temizliği, dezenfeksiyon ve performans kontrolü.</p>
          <a href="#" class="text-brand-orange font-semibold text-sm nav-link focus-visible:outline-2 focus-visible:outline-brand-orange">Detaylı Bilgi &rarr;</a>
        </div>
        <!-- Card 3: Air Quality -->
        <div class="card-lift bg-white rounded-2xl shadow-card p-7 text-center">
          <div class="w-16 h-16 bg-brand-orange/10 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Klima Tamir</h3>
          <p class="text-text-body text-sm leading-relaxed mb-4">Her marka ve model klimanın arıza tespiti ve tamiri. Soğutmayan, su akan, ses yapan klima sorunlarını çözüyoruz.</p>
          <a href="#" class="text-brand-orange font-semibold text-sm nav-link focus-visible:outline-2 focus-visible:outline-brand-orange">Detaylı Bilgi &rarr;</a>
        </div>
        <!-- Card 4: Maintenance -->
        <div class="card-lift bg-white rounded-2xl shadow-card p-7 text-center">
          <div class="w-16 h-16 bg-brand-orange/10 rounded-xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-brand-navy mb-3">Gaz Dolumu</h3>
          <p class="text-text-body text-sm leading-relaxed mb-4">Klima gaz dolumu ve kaçak tespiti. R410A, R32 ve R22 gazları ile profesyonel dolum hizmeti.</p>
          <a href="#" class="text-brand-orange font-semibold text-sm nav-link focus-visible:outline-2 focus-visible:outline-brand-orange">Detaylı Bilgi &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 5: ABOUT / HAKKIMIZDA ============ -->
  <!-- Part A: Dark navy banner -->
  <section id="about" class="relative overflow-hidden" style="background-color: #1a2e3b; padding-top: 5rem; padding-bottom: 5.5rem;">
    <!-- Top curve from cream -->
    <svg class="absolute top-0 left-0 w-full" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="margin-top: -1px;">
      <path d="M0,0 L1440,0 L1440,60 C960,0 480,0 0,60 Z" fill="#f5f0eb"/>
    </svg>
    <!-- Background image, subtle -->
    <div class="absolute inset-0" style="opacity: 0.12;">
      <img src="/brand_assets/technician-customer-indoor.webp" alt="" class="w-full h-full object-cover">
    </div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(26,46,59,0.97) 0%, rgba(42,125,138,0.55) 100%);"></div>
    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block text-brand-orange font-bold text-sm uppercase tracking-widest mb-4">Hakkımızda</span>
      <h2 class="font-heading text-4xl sm:text-5xl font-extrabold text-white tracking-[-0.03em]">EKİBİMİZLE TANIŞIN</h2>
    </div>
    <!-- Wave bottom → white -->
    <svg class="absolute bottom-0 left-0 w-full" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,80 C360,20 1080,20 1440,80 L1440,80 L0,80 Z" fill="white"/>
    </svg>
  </section>

  <!-- Part B: Story section -->
  <section class="relative bg-white pb-20 overflow-hidden">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-16">
      <!-- Company photo -->
      <div class="rounded-2xl overflow-hidden shadow-card mb-10 relative">
        <img src="/brand_assets/technician-rooftop.webp" alt="Şanlıurfa Klima Servisi ekibi" class="w-full object-cover" style="height: 320px;">
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
      </div>
      <!-- Heading -->
      <h3 class="font-heading text-2xl sm:text-3xl font-extrabold text-brand-navy mb-6 tracking-[-0.03em]">NASIL BAŞLADIK?</h3>
      <!-- Body -->
      <p class="text-text-body leading-relaxed mb-5" style="line-height: 1.7;">
        Şanlıurfa'nın kavurucu yazlarında bile evinizin serin olması gerektiğine inanıyoruz. Yıllar önce, bir teknisyen olarak çalışırken müşterilerin haksız faturalardan, tutarsız servislerden ve güvensiz ustalardan ne kadar bıktığını bizzat gördük. Daha iyi bir şey kurma vakti gelmişti.
      </p>
      <p class="text-text-body leading-relaxed mb-12" style="line-height: 1.7;">
        20 yılı aşkın deneyimimizle bugüne kadar 5.000'den fazla aileye ve işletmeye hizmet verdik. Ekibimiz lisanslı, sigortalı ve her müşteriyi komşusu gibi gören insanlardan oluşuyor. Gizli ücret yok, sürpriz fatura yok — sadece dürüst, hızlı ve kaliteli iş.
      </p>
      <!-- Trust badge row -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-4 py-3 shadow-sm">
          <svg class="w-5 h-5 text-yellow-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <span class="font-heading font-bold text-brand-navy text-sm">Google 5.0 Puan</span>
        </div>
        <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-4 py-3 shadow-sm">
          <svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span class="font-heading font-bold text-brand-navy text-sm">Lisanslı & Sigortalı</span>
        </div>
        <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-4 py-3 shadow-sm">
          <svg class="w-5 h-5 text-brand-teal flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
          <span class="font-heading font-bold text-brand-navy text-sm">20+ Yıllık Deneyim</span>
        </div>
        <div class="flex items-center gap-2 border border-gray-200 rounded-xl px-4 py-3 shadow-sm">
          <svg class="w-5 h-5 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v3h8v-3zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-3a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v3h-3zM4.75 12.094A5.973 5.973 0 004 15v3H1v-3a3 3 0 013.75-2.906z"/></svg>
          <span class="font-heading font-bold text-brand-navy text-sm">5.000+ Mutlu Müşteri</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 6: ADDITIONAL SERVICES / STATS ============ -->
  <section class="relative bg-brand-cream py-20 overflow-hidden">
    <svg class="absolute top-0 left-0 w-full" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="margin-top: -1px;">
      <path d="M0,0 L1440,0 L1440,60 C960,0 480,0 0,60 Z" fill="white"/>
    </svg>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
      <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16">
        <!-- Content Left -->
        <div class="w-full lg:w-7/12">
          <span class="text-brand-orange font-bold text-sm uppercase tracking-widest">Nasıl Çalışıyoruz</span>
          <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-brand-navy mt-3 mb-6 tracking-[-0.03em]">GÜVENEBİLECEĞİNİZ<br>SONUÇLAR SUNUYORUZ</h2>
          <p class="text-text-body leading-relaxed mb-8" style="line-height: 1.7;">
            İlk görüşmeden son kontrole kadar sürecimiz sizin memnuniyetiniz üzerine kurulu. Her evi kendi evimiz, her müşteriyi ailemiz gibi görüyoruz.
          </p>
          <div class="grid grid-cols-2 gap-6">
            <div class="text-center p-5 bg-white rounded-2xl shadow-card">
              <div class="font-heading text-4xl font-extrabold text-brand-orange">20+</div>
              <div class="text-text-body text-sm mt-1 font-medium">Yıllık Deneyim</div>
            </div>
            <div class="text-center p-5 bg-white rounded-2xl shadow-card">
              <div class="font-heading text-4xl font-extrabold text-brand-orange">5.000+</div>
              <div class="text-text-body text-sm mt-1 font-medium">Mutlu Müşteri</div>
            </div>
            <div class="text-center p-5 bg-white rounded-2xl shadow-card">
              <div class="font-heading text-4xl font-extrabold text-brand-orange">7/24</div>
              <div class="text-text-body text-sm mt-1 font-medium">Acil Servis</div>
            </div>
            <div class="text-center p-5 bg-white rounded-2xl shadow-card">
              <div class="font-heading text-4xl font-extrabold text-brand-orange">%100</div>
              <div class="text-text-body text-sm mt-1 font-medium">Memnuniyet Oranı</div>
            </div>
          </div>
        </div>
        <!-- Image Right -->
        <div class="w-full lg:w-5/12 relative">
          <div class="rounded-2xl overflow-hidden shadow-card">
            <img src="/brand_assets/diagnostic-tools.webp" alt="Klima servis çalışması" class="w-full h-auto object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent rounded-2xl"></div>
          </div>
          <div class="absolute -top-4 -left-4 w-24 h-24 bg-brand-orange/20 rounded-2xl -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SECTION 7: CUSTOMER REVIEWS ============ -->
  <section id="reviews" class="relative bg-white py-20 overflow-hidden">
    <svg class="absolute top-0 left-0 w-full" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" style="margin-top: -1px;">
      <path d="M0,0 L1440,0 L1440,60 C960,0 480,0 0,60 Z" fill="#f5f0eb"/>
    </svg>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10">
      <div class="text-center mb-14">
        <span class="text-brand-orange font-bold text-sm uppercase tracking-widest">Müşteri Yorumları</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-brand-navy mt-3 tracking-[-0.03em]">MÜŞTERİLERİMİZ NE DİYOR?</h2>
        <div class="w-16 h-1 bg-brand-orange mx-auto mt-4 rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Review 1 -->
        <div class="card-lift bg-white rounded-2xl shadow-card p-7 border border-gray-100">
          <div class="flex gap-1 mb-4">
